BATCH_TRANSFORM_INPUT_S3_BUCKET=curriculum-map-testing-bucket
AWS_REGION=ca-central-1
ACCESS_KEY= # TODO: Fill in
SECRET_KEY= # TODO: Fill in
LO_MAPPING_DYNAMODB_REQUESTS_TABLE=lo-mapping-requests
HF_MODEL_ID=Qwen/Qwen3-8B
