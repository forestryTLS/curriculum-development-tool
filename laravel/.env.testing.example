# Test environment configuration.
# Copy to .env.testing, point DB_DATABASE at a SEPARATE database from
# your dev .env, generate a key with `php artisan key:generate --env=testing`,
# then run `composer test`. The composer script runs migrate:fresh --seed
# against this connection and then php artisan test.

APP_NAME=Laravel
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel_test
DB_USERNAME=root
DB_PASSWORD=

# The following are Required only for E2E tests

# Defaults to "python" on Windows, "python3" on macOS/Linux if unset.
# E2E_PYTHON_BIN=python

E2E_LARAVEL_PORT=8010

# Set these to a resolution SMALLER than your monitor's resolution
# It prevents some flakiness from elements from going off-screen
PLAYWRIGHT_VIEWPORT_WIDTH=1280
PLAYWRIGHT_VIEWPORT_HEIGHT=720
